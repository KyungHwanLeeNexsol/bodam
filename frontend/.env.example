# 보담 프론트엔드 환경 변수 예시
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env

# =============================================================================
# 필수 (Required)
# =============================================================================

# 백엔드 API URL
# 개발: http://localhost:8000
# 프로덕션: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# 선택 (Optional)
# =============================================================================

# 앱 이름 (브라우저 탭 및 메타 태그에 사용)
NEXT_PUBLIC_APP_NAME=보담

# Node.js 환경 (development | production | test)
NODE_ENV=development
