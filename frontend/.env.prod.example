# 보담 프론트엔드 프로덕션 환경 변수 템플릿
# 사용법: cp frontend/.env.prod.example frontend/.env.prod
# 주의: .env.prod 파일은 절대 git에 커밋하지 마세요!
# 참고: NEXT_PUBLIC_ 접두사가 있는 변수는 브라우저에도 노출됩니다.

# ===========================================================================
# API 엔드포인트 설정 (실제 도메인으로 변경)
# ===========================================================================
NEXT_PUBLIC_API_URL=https://your-domain.com

# ===========================================================================
# 앱 기본 설정
# ===========================================================================
NEXT_PUBLIC_APP_NAME=보담

# ===========================================================================
# Node.js 환경 설정
# ===========================================================================
NODE_ENV=production

# ===========================================================================
# Next.js 텔레메트리 비활성화 (선택사항)
# ===========================================================================
NEXT_TELEMETRY_DISABLED=1
