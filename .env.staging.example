# ============================================================
# 보담 스테이징 환경변수 레퍼런스
# 스테이징 환경 (docker-compose.staging.yml 참조)
# 사용법: cp .env.staging.example .env.staging
# 주의: .env.staging 파일은 절대 git에 커밋하지 마세요!
# 참고: 스테이징은 프로덕션과 동일한 변수 세트를 사용합니다.
#       값만 스테이징 환경에 맞게 변경하세요.
# ============================================================

# === [필수] 데이터베이스 ===
POSTGRES_DB=bodam_staging
POSTGRES_USER=bodam
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://bodam:CHANGE_ME@postgres:5432/bodam_staging

# === [필수] 캐시 (Redis) ===
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# === [필수] 인증 / 보안 ===
# SECRET_KEY 생성: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_STAGING_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === [필수] LLM API 키 ===
# Gemini API 키 (config.py 필드: gemini_api_key)
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY

# === [선택] LLM 라우팅 설정 ===
LLM_PRIMARY_MODEL=gemini-2.0-flash
LLM_FALLBACK_MODEL=gemini-2.0-flash
LLM_CLASSIFIER_MODEL=gemini-2.0-flash
LLM_CONFIDENCE_THRESHOLD=0.7
LLM_FALLBACK_ON_LOW_CONFIDENCE=true
LLM_COST_TRACKING_ENABLED=true

# === [선택] Chat AI 설정 ===
CHAT_MODEL=gemini-2.0-flash
CHAT_MAX_TOKENS=1024
CHAT_TEMPERATURE=0.3
CHAT_HISTORY_LIMIT=10
CHAT_CONTEXT_TOP_K=5
CHAT_CONTEXT_THRESHOLD=0.3

# === [선택] 임베딩 / RAG 설정 ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100

# === [선택] 크롤러 설정 ===
CRAWLER_STORAGE_BACKEND=local
CRAWLER_BASE_DIR=./data/crawled_pdfs
CRAWLER_RATE_LIMIT_SECONDS=2.0
CRAWLER_MAX_RETRIES=3

# === [선택] 오브젝트 스토리지 (OCI Object Storage / S3 호환) ===
STORAGE_BACKEND=local
MINIO_BUCKET=bodam-pdfs-staging
MINIO_REGION=ap-chuncheon-1
MINIO_ENDPOINT=https://ACCOUNT_ID.compat.objectstorage.REGION.oraclecloud.com
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY

# === [선택] Rate Limiting ===
RATE_LIMIT_GENERAL=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_CHAT_DAILY=100

# === [필수] CORS 설정 ===
# 스테이징 프론트엔드 도메인
ALLOWED_ORIGINS=https://bodam-staging.vercel.app

# === [선택] OAuth2 소셜 로그인 ===
# 카카오 (developers.kakao.com)
KAKAO_CLIENT_ID=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
KAKAO_REDIRECT_URI=https://bodam-staging.vercel.app/auth/callback/kakao

# 네이버 (developers.naver.com)
NAVER_CLIENT_ID=CHANGE_ME
NAVER_CLIENT_SECRET=CHANGE_ME
NAVER_REDIRECT_URI=https://bodam-staging.vercel.app/auth/callback/naver

# 구글 (console.cloud.google.com)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://bodam-staging.vercel.app/auth/callback/google

# === [선택] 보안 암호화 키 ===
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SOCIAL_TOKEN_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
B2B_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# === 앱 기본 설정 (스테이징 전용 값) ===
APP_NAME=Bodam API (Staging)
DEBUG=true
ENVIRONMENT=staging
LOG_LEVEL=debug
