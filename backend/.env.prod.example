# 보담 백엔드 프로덕션 환경 변수 템플릿
# 사용법: cp backend/.env.prod.example backend/.env.prod
# 주의: .env.prod 파일은 절대 git에 커밋하지 마세요!

# ===========================================================================
# 데이터베이스 설정 (Docker 내부 네트워크 - 서비스명 "postgres" 사용)
# ===========================================================================
DATABASE_URL=postgresql+asyncpg://bodam:CHANGE_ME@postgres:5432/bodam
POSTGRES_DB=bodam
POSTGRES_USER=bodam
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===========================================================================
# Redis 캐시 설정 (Docker 내부 네트워크 - 서비스명 "redis" 사용)
# ===========================================================================
REDIS_URL=redis://redis:6379/0

# ===========================================================================
# JWT 보안 설정
# SECRET_KEY 생성 방법: openssl rand -hex 32
# ===========================================================================
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX_GENERATED_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================================================
# AI API 키
# ===========================================================================
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY

# ===========================================================================
# CORS 설정 (실제 도메인으로 변경)
# 여러 도메인은 쉼표로 구분: https://domain1.com,https://domain2.com
# ===========================================================================
ALLOWED_ORIGINS=https://your-domain.com

# ===========================================================================
# 프로덕션 애플리케이션 설정
# ===========================================================================
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false
