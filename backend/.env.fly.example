# 보담 백엔드 Fly.io 환경 변수 템플릿
# 설정 방법: fly secrets set KEY=VALUE --app bodam
# 또는: 이 파일을 .env.fly로 복사 후 값 입력, fly secrets import < backend/.env.fly
# 주의: CHANGE_ME 값을 반드시 실제 값으로 변경 후 사용하세요

# ===========================================================================
# 데이터베이스 설정 (Neon PostgreSQL + pgvector)
# Neon 대시보드 → Connection Details → Connection string (asyncpg)
# 형식: postgresql+asyncpg://user:password@host/dbname?sslmode=require
# ===========================================================================
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-northeast-1.aws.neon.tech/bodam?sslmode=require

# ===========================================================================
# Redis 설정 (Upstash Redis)
# Upstash 대시보드 → Redis → Connect → rediss:// URL 사용 (TLS 필수)
# ===========================================================================
REDIS_URL=rediss://default:password@apn1-xxx.upstash.io:6379

# ===========================================================================
# JWT 보안 설정
# SECRET_KEY 생성: openssl rand -hex 32
# 중요: 기존에 사용하던 키를 그대로 사용해야 기존 JWT 토큰 유효
# ===========================================================================
SECRET_KEY=CHANGE_ME

# ===========================================================================
# AI API 키
# ===========================================================================
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY

# ===========================================================================
# OAuth2 소셜 로그인 (카카오, 네이버, 구글)
# 중요: 각 OAuth 제공자 대시보드에서 리다이렉트 URI도 아래 값으로 변경 필요
# ===========================================================================
KAKAO_CLIENT_ID=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
KAKAO_REDIRECT_URI=https://bodam.fly.dev/api/v1/auth/oauth/kakao/callback

NAVER_CLIENT_ID=CHANGE_ME
NAVER_CLIENT_SECRET=CHANGE_ME
NAVER_REDIRECT_URI=https://bodam.fly.dev/api/v1/auth/oauth/naver/callback

GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://bodam.fly.dev/api/v1/auth/oauth/google/callback

# ===========================================================================
# 암호화 키 (Fernet 대칭키)
# 중요: 기존에 사용하던 키를 그대로 사용해야 기존 암호화 데이터 복호화 가능
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ===========================================================================
SOCIAL_TOKEN_ENCRYPTION_KEY=CHANGE_ME
B2B_ENCRYPTION_KEY=CHANGE_ME

# ===========================================================================
# CORS 설정
# Vercel 프론트엔드 도메인 (쉼표로 여러 도메인 가능)
# ===========================================================================
ALLOWED_ORIGINS=https://bodam-one.vercel.app

# ===========================================================================
# 프로덕션 설정
# ===========================================================================
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false
