# 보담 백엔드 Fly.io 환경 변수 템플릿
# 설정 방법: fly secrets set KEY=VALUE --app bodam-backend
# 또는: fly secrets import < backend/.env.fly (실제 값 입력 후)
# 주의: 이 파일을 직접 fly secrets로 import하지 마세요 (CHANGE_ME 값 포함)

# ===========================================================================
# 데이터베이스 설정 (Neon PostgreSQL + pgvector)
# Neon 대시보드 → Connection Details → Connection string (asyncpg)
# 형식: postgresql+asyncpg://user:password@host/dbname?sslmode=require
# ===========================================================================
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ===========================================================================
# Redis 설정 (Upstash Redis)
# Upstash 대시보드 → Redis → Connect → rediss:// URL 사용 (TLS)
# ===========================================================================
REDIS_URL=rediss://default:password@us1-xxx.upstash.io:6379

# ===========================================================================
# JWT 보안 설정
# SECRET_KEY 생성: openssl rand -hex 32
# ===========================================================================
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================================================
# AI API 키
# ===========================================================================
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY

# ===========================================================================
# CORS 설정
# Vercel 배포 후 실제 URL로 변경: https://bodam.vercel.app
# ===========================================================================
ALLOWED_ORIGINS=https://bodam.vercel.app

# ===========================================================================
# 프로덕션 설정
# ===========================================================================
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false
