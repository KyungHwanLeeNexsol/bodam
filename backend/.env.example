# Bodam Backend 환경변수 설정 예시 (SPEC-SEC-001 M4)
# 실제 운영 환경에서는 이 파일을 복사하여 .env 파일을 생성하고 값을 교체하세요.
# 절대 실제 시크릿 값을 이 파일에 저장하지 마세요.

# =============================================================================
# [필수] 데이터베이스 설정
# =============================================================================
# PostgreSQL 연결 URL (asyncpg 드라이버 사용)
# 형식: postgresql+asyncpg://{user}:{password}@{host}:{port}/{database}
DATABASE_URL=postgresql+asyncpg://bodam:CHANGE_ME_DB_PASSWORD@localhost:5432/bodam

# =============================================================================
# [필수] 캐시 / Rate Limiting
# =============================================================================
# Redis 연결 URL (Rate Limiting, 세션 캐시 등에 사용)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# [필수] 인증 및 보안
# =============================================================================
# JWT 서명에 사용하는 시크릿 키 (최소 32자 이상의 무작위 문자열)
# 생성 예시: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# JWT 서명 알고리즘 (기본값: HS256)
JWT_ALGORITHM=HS256

# JWT 액세스 토큰 만료 시간 (분, 기본값: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# [필수] LLM API 키
# =============================================================================
# OpenAI API 키 (임베딩 및 GPT 모델 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_API_KEY

# Google Gemini API 키 (주요 LLM 라우팅 대상)
# https://makersuite.google.com/app/apikey 에서 발급
GOOGLE_API_KEY=AIzaCHANGE_ME_GOOGLE_API_KEY

# =============================================================================
# [필수] 보안 설정 (SPEC-SEC-001)
# =============================================================================
# 프로덕션 CORS 허용 도메인 (쉼표 구분)
# 개발 환경에서는 비워두면 localhost:3000이 자동으로 허용됨
# 예: https://bodam.kr,https://api.bodam.kr
ALLOWED_ORIGINS=

# =============================================================================
# [선택] 앱 기본 설정
# =============================================================================
# 디버그 모드 (프로덕션에서는 반드시 false로 설정)
DEBUG=false

# 앱 이름 (API 문서 등에 표시)
APP_NAME=Bodam API

# =============================================================================
# [선택] Rate Limiting 설정 (기본값 사용 권장)
# =============================================================================
# IP 기반 일반 API 요청 제한 (요청/분)
RATE_LIMIT_GENERAL=60

# IP 기반 인증 엔드포인트 요청 제한 (요청/분, 브루트포스 방지)
RATE_LIMIT_AUTH=10

# Free Tier 사용자 일일 채팅 요청 제한
RATE_LIMIT_CHAT_DAILY=100

# =============================================================================
# [선택] OAuth2 소셜 로그인 (SPEC-OAUTH-001)
# =============================================================================
# 카카오 OAuth2 설정 (https://developers.kakao.com 에서 발급)
KAKAO_CLIENT_ID=CHANGE_ME_KAKAO_CLIENT_ID
KAKAO_CLIENT_SECRET=CHANGE_ME_KAKAO_CLIENT_SECRET
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/kakao

# 네이버 OAuth2 설정 (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=CHANGE_ME_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=CHANGE_ME_NAVER_CLIENT_SECRET
NAVER_REDIRECT_URI=http://localhost:3000/auth/callback/naver

# 구글 OAuth2 설정 (https://console.cloud.google.com 에서 발급)
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# 소셜 토큰 암호화 키 (Fernet 키, 32바이트 base64)
# 생성 예시: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SOCIAL_TOKEN_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# =============================================================================
# [필수] B2B PII 암호화 설정 (SPEC-B2B-001)
# =============================================================================
# B2B 고객 개인정보(PII) 암호화 키 (Fernet 키, 32바이트 base64)
# PIPA(개인정보보호법) 준수를 위한 고객 PII 암호화에 사용
# 생성 예시: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
B2B_ENCRYPTION_KEY=CHANGE_ME_B2B_FERNET_KEY

# =============================================================================
# [선택] 크롤러 설정
# =============================================================================
# 스토리지 백엔드 (local 또는 s3)
CRAWLER_STORAGE_BACKEND=local

# 로컬 스토리지 기본 디렉토리
CRAWLER_BASE_DIR=./data/crawled_pdfs

# =============================================================================
# [선택] MinIO 오브젝트 스토리지 (SPEC-CRAWLER-002)
# S3 호환 오브젝트 스토리지. STORAGE_BACKEND=s3 시 사용.
# docker compose up으로 MinIO 서버 시작 (포트 9000, 콘솔 9001)
# =============================================================================
# 스토리지 백엔드 선택 (local | s3)
STORAGE_BACKEND=local

# MinIO/S3 엔드포인트 URL (로컬 MinIO: http://localhost:9000, AWS S3: 설정하지 않음)
MINIO_ENDPOINT=http://localhost:9000

# MinIO 액세스 키 (docker-compose MINIO_ROOT_USER와 일치)
MINIO_ACCESS_KEY=bodam

# MinIO 시크릿 키 (docker-compose MINIO_ROOT_PASSWORD와 일치)
MINIO_SECRET_KEY=bodam_minio_secret

# PDF 저장 버킷 이름
MINIO_BUCKET=bodam-pdfs

# 로컬 스토리지 경로 (STORAGE_BACKEND=local 시 사용)
PDF_STORAGE_PATH=./data/crawled_pdfs

# =============================================================================
# [선택] LLM 라우팅 설정
# =============================================================================
# 주요 LLM 모델명
LLM_PRIMARY_MODEL=gemini-2.0-flash

# 폴백 LLM 모델명
LLM_FALLBACK_MODEL=gpt-4o
