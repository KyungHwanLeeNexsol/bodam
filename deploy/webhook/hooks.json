[
  {
    "id": "deploy-bodam",
    "execute-command": "/home/ubuntu/bodam/deploy/scripts/deploy.sh",
    "command-working-directory": "/home/ubuntu/bodam",
    "response-message": "배포 시작됨",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hash-sha256",
            "secret": "WEBHOOK_SECRET_CHANGE_ME",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
